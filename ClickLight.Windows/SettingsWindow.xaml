<Window x:Class="ClickLight.Windows.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ClickLight Settings"
        Width="420" Height="620"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#1E1E2E">
    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#CDD6F4"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="#CDD6F4"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Margin" Value="0,4"/>
        </Style>
        <Style TargetType="Slider">
            <Setter Property="Margin" Value="0,4,0,8"/>
        </Style>
    </Window.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
    <StackPanel Margin="20">
        <TextBlock Text="ClickLight Settings" FontSize="18" FontWeight="Bold" Margin="0,0,0,16" Foreground="#89B4FA"/>

        <!-- Enable toggle -->
        <CheckBox x:Name="EnabledCheck" Content="Enabled" Margin="0,0,0,4"/>
        <CheckBox x:Name="LaunchAtLoginCheck" Content="Launch at Login" Margin="0,0,0,12"/>

        <!-- Click types -->
        <TextBlock Text="Click Types" FontWeight="SemiBold" Margin="0,8,0,4" Foreground="#A6ADC8"/>
        <CheckBox x:Name="ShowPressCheck" Content="Show Press"/>
        <CheckBox x:Name="ShowReleaseCheck" Content="Show Release"/>
        <CheckBox x:Name="ShowRightClickCheck" Content="Show Right-Click"/>
        <CheckBox x:Name="ShowDragCheck" Content="Show Drag"/>

        <!-- Size -->
        <TextBlock Margin="0,12,0,2">
            <Run Text="Size: "/><Run x:Name="SizeLabel" Text="64"/>
        </TextBlock>
        <Slider x:Name="SizeSlider" Minimum="20" Maximum="150" TickFrequency="1" IsSnapToTickEnabled="True"/>

        <!-- Duration -->
        <TextBlock Margin="0,4,0,2">
            <Run Text="Duration: "/><Run x:Name="DurationLabel" Text="0.48s"/>
        </TextBlock>
        <Slider x:Name="DurationSlider" Minimum="0.1" Maximum="1.5" TickFrequency="0.01" IsSnapToTickEnabled="True"/>

        <!-- Intensity -->
        <TextBlock Margin="0,4,0,2">
            <Run Text="Intensity: "/><Run x:Name="IntensityLabel" Text="0.70"/>
        </TextBlock>
        <Slider x:Name="IntensitySlider" Minimum="0.1" Maximum="1.5" TickFrequency="0.01" IsSnapToTickEnabled="True"/>

        <!-- Color preset -->
        <TextBlock Text="Color" Margin="0,12,0,4" FontWeight="SemiBold" Foreground="#A6ADC8"/>
        <StackPanel Orientation="Horizontal">
            <ComboBox x:Name="ColorCombo" Width="160"/>
            <Button x:Name="CustomColorButton" Content="Pick Custom..." Padding="8,4" Margin="8,0,0,0"/>
        </StackPanel>

        <!-- Buttons -->
        <StackPanel Orientation="Horizontal" Margin="0,20,0,0">
            <Button x:Name="TestButton" Content="Test Pulse" Padding="12,6" Margin="0,0,8,0"/>
            <Button x:Name="ResetButton" Content="Reset Defaults" Padding="12,6"/>
        </StackPanel>
    </StackPanel>
    </ScrollViewer>
</Window>
